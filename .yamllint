extends: default

rules:
  line-length:
    max: 160
    level: warning

  document-start: disable

  truthy:
    allowed-values: ["true", "false", "on", "off"]

  comments:
    min-spaces-from-content: 1

  indentation:
    spaces: 2
    indent-sequences: consistent

ignore: |
  .git/
  .github/
  docs/performance/
  snapshot-*.txt
